{
  "compilerOptions": {
    "target": "es2022",
    "module": "esnext",
    "moduleResolution": "bundler",
    "strict": true,
    "skipLibCheck": true,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@bibixx/workoutkit": ["../sdk/src/index.ts"],
      "@bibixx/workoutkit/encode": ["../sdk/src/encode-api.ts"],
      "@bibixx/workoutkit/decode": ["../sdk/src/decode-api.ts"],
      "@bibixx/workoutkit/fs": ["../sdk/src/fs.ts"]
    }
  },
  "include": ["src", "vitest.config.ts"]
}
