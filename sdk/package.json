{
  "name": "@bibixx/workoutkit",
  "version": "0.2.0",
  "description": "TypeScript SDK for reading and writing Apple's .workout file format (WorkoutKit).",
  "keywords": [
    "apple",
    "fitness",
    "healthkit",
    "ios",
    "protobuf",
    "watchos",
    "workout",
    "workoutkit"
  ],
  "homepage": "https://github.com/bibixx/workoutkit#readme",
  "bugs": "https://github.com/bibixx/workoutkit/issues",
  "license": "MIT",
  "author": "Bartosz Legięć",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bibixx/workoutkit.git",
    "directory": "sdk"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./encode": {
      "types": "./dist/encode.d.ts",
      "import": "./dist/encode.js",
      "require": "./dist/encode.cjs"
    },
    "./decode": {
      "types": "./dist/decode.d.ts",
      "import": "./dist/decode.js",
      "require": "./dist/decode.cjs"
    },
    "./fs": {
      "types": "./dist/fs.d.ts",
      "import": "./dist/fs.js",
      "require": "./dist/fs.cjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "prepack": "cp ../README.md ./README.md && cp ../LICENSE ./LICENSE",
    "postpack": "rm -f ./README.md ./LICENSE",
    "prepublishOnly": "lefthook run prepublish && tsup"
  },
  "devDependencies": {
    "@types/node": "^20.12.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=18"
  }
}
